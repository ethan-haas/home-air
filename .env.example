# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# ---- goal ----
HA_TARGET_F=70

# ---- ecobee (read Ethan's-room sensor) ----
# NOTE: ecobee has CLOSED new developer-API registrations, so a personal API key
# is likely unavailable. Use the web-app credentials captured from browser
# devtools (F12 -> Network -> a request to api.ecobee.com/token):
#   ECOBEE_TOKEN         = the access_token (Bearer), expires ~1h
#   ECOBEE_REFRESH_TOKEN = the refresh_token from the same token response
#   ECOBEE_CLIENT_ID     = the client_id sent in that token request (public)
# With refresh_token + client_id the service auto-renews the access token, so the
# hourly expiry stops mattering.
ECOBEE_TOKEN=
ECOBEE_REFRESH_TOKEN=
# ECOBEE_CLIENT_ID is optional — defaults to the ecobee web app's public client_id
# (verified live). Only set it if ecobee changes that id.
ECOBEE_CLIENT_ID=
# Legacy only (if you already hold a developer key): used as client_id fallback.
ECOBEE_API_KEY=

# ---- midea (office AC) — get these once via scripts/discover_midea.py ----
MIDEA_HOST=
MIDEA_ID=
MIDEA_TOKEN=
MIDEA_KEY=

# ---- ecobee thermostat id (from your ecobee account) ----
ECOBEE_THERMOSTAT_ID=

# ---- location for Open-Meteo weather (your coordinates) ----
HA_LAT=
HA_LON=
